# LLM proxy config for the dev server (copy to .env.local and fill in).
# The dev server forwards /llm -> LLM_UPSTREAM with this key attached,
# so the key never reaches the browser and there is no CORS problem.

# Groq — FREE tier, fast, no credit card. Get a key at https://console.groq.com/keys
LLM_UPSTREAM=https://api.groq.com/openai/v1
LLM_API_KEY=

# Optional: default live-run backend URL baked into the build, so the deployed
# site reaches the real CrewAI backend without editing Settings. Must start with
# VITE_ to be exposed to the frontend. Set this in Netlify env for production.
# VITE_BACKEND_URL=https://crewai-live-run.onrender.com

# --- other OpenAI-compatible providers (uncomment one) ---
# OpenAI (paid):
# LLM_UPSTREAM=https://api.openai.com/v1
# Google Gemini (free tier):
# LLM_UPSTREAM=https://generativelanguage.googleapis.com/v1beta/openai
