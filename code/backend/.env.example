# ---- Outlook (Microsoft Graph, app-only client credentials) ----
# From your Azure AD app registration. The app needs the APPLICATION permission
# Mail.Read (admin-consented). App-only auth has no signed-in user, so you must
# name the mailbox to read with OUTLOOK_USER.
OUTLOOK_CLIENT_ID=
OUTLOOK_TENANT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_USER=someone@yourtenant.onmicrosoft.com

# ---- LLM (used by CrewAI agents to reason) ----
# Any OpenAI-compatible endpoint. The frontend can also send these per-run, but
# these are the server defaults / fallback.
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=groq/llama-3.3-70b-versatile

# CORS: where the frontend dev server runs.
FRONTEND_ORIGIN=http://localhost:3000
